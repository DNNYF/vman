# --- VMAN configuration placeholders ---
# Copy to .env (which is git-ignored) and fill in real values.
# NEVER commit a real .env or any real master keys/secrets.

# Runtime environment: development | production
VMAN_ENV=development

# SQLite default; PostgreSQL-ready abstraction exists for later
VMAN_DATABASE_URL=sqlite:///./data/vman.db

# Queue backend: sqlite | redis  (sqlite = MVP, no external service required)
VMAN_QUEUE_BACKEND=sqlite

# Master encryption key for credential vault.
# Generate with: python scripts/generate-master-key.py
# 32-byte URL-safe base64 = 44 chars. KEEP OUT OF REPO AND BACKUPS YOU DON'T FULLY CONTROL.
VMAN_MASTER_KEY=replace-with-32-byte-urlsafe-base64-key

# Session signing secret. Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
VMAN_SESSION_SECRET=replace-with-long-random-secret

# Comma-separated origins for CORS (no trailing slash, https in production)
VMAN_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Trust X-Forwarded-For only when a reverse proxy sanitizes it.
VMAN_TRUSTED_PROXY_HOPS=0

# API bind host/port
VMAN_API_HOST=127.0.0.1
VMAN_API_PORT=8765

# Concurrency / low-resource knobs (small VPS friendly)
VMAN_UVICORN_WORKERS=1
VMAN_WORKER_CONCURRENCY=1
VMAN_MAX_PARALLEL_HOST_JOBS=1
VMAN_MAX_GLOBAL_JOBS=1

# Frontend serving mode: static (recommended) | dev
VMAN_FRONTEND_MODE=static

# Disable optional heavy features by default
VMAN_ENABLE_REDIS=false
VMAN_ENABLE_PLAYWRIGHT_LOCAL=false

# Retention
VMAN_LOG_RETENTION_DAYS=7
VMAN_METRICS_RETENTION_DAYS=7

# Optional Redis (only used if VMAN_ENABLE_REDIS=true and VMAN_QUEUE_BACKEND=redis)
# VMAN_REDIS_URL=redis://127.0.0.1:6379/0

# SSH runner defaults
VMAN_SSH_CONNECT_TIMEOUT_SECONDS=10
VMAN_SSH_COMMAND_TIMEOUT_SECONDS=300

# Logging
VMAN_LOG_LEVEL=INFO
